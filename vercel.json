{
  "version": 2,
  "name": "hotdogtony",
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    },
    {
      "src": "/[^.]+",
      "dest": "/client/index.html"
    }
  ]
}
